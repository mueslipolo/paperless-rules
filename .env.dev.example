# Laptop dev preset — point at remote paperless, test rules read-only.
#
# Usage:
#   cp .env.dev.example .env
#   uv run paperless-rules editor      # http://localhost:8765
#
# The editor loads docs and runs match regexes against them, but every
# mutating route (rule writes, deletes, post-consume, non-dry-run apply)
# returns 405. Safe to leave running while you experiment.

# ── paperless connection (point at your real instance) ───────────────
PAPERLESS_URL=https://paperless.your-syno.lan
PAPERLESS_TOKEN=replace-me-with-a-paperless-api-token
PAPERLESS_VERIFY_SSL=true       # set false if you trust a self-signed LAN cert

# ── paths (local checkout) ───────────────────────────────────────────
RULES_DIR=./rules
STATE_DIR=./state

# ── editor ────────────────────────────────────────────────────────────
EDITOR_ENABLED=true
EDITOR_HOST=127.0.0.1            # localhost only — don't expose dev mode on LAN
EDITOR_PORT=8765
EDITOR_AUTH_REQUIRED=false       # token comes from PAPERLESS_TOKEN above (server-side)
EDITOR_READONLY=true             # the whole point — no PATCHes from your laptop

# ── runtime ───────────────────────────────────────────────────────────
RUNTIME_MODE=disabled            # editor only — no background polling on laptop

LOG_LEVEL=INFO
