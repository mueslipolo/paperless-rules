# Production preset — editor + post-consume + manual backfill.
#
# Wire paperless's PAPERLESS_POST_CONSUME_SCRIPT to call our webhook (see
# scripts/post_consume_via_rules.sh). Use the editor's Backfill button
# for historical sweeps and rule-change rollouts.
#
# Poller is OFF — post-consume covers new docs and backfill covers the
# rest. If you can't wire post-consume, switch RUNTIME_MODE=poller below.

# ── paperless connection ──────────────────────────────────────────────
PAPERLESS_URL=http://paperless-webserver:8000     # docker-network DNS
PAPERLESS_TOKEN=replace-me-with-a-paperless-api-token
PAPERLESS_VERIFY_SSL=true

# ── paths ─────────────────────────────────────────────────────────────
RULES_DIR=/data/rules
STATE_DIR=/data/state

# ── editor ────────────────────────────────────────────────────────────
EDITOR_ENABLED=true
EDITOR_HOST=0.0.0.0
EDITOR_PORT=8765
EDITOR_AUTH_REQUIRED=true
EDITOR_READONLY=false

# ── runtime ───────────────────────────────────────────────────────────
RUNTIME_MODE=disabled            # post-consume + backfill cover everything
POLL_INTERVAL_SECONDS=60         # only relevant if RUNTIME_MODE=poller
POLL_FILTER=

LOG_LEVEL=INFO
TZ=UTC
