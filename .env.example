# Copy to `.env` and fill in. Both the editor and the runtime read these.
#
# Three deployment presets covered below — pick one and uncomment.
#
#   • dev      laptop / read-only / no auth — for testing rules against a
#              remote paperless without risking a stray PATCH.
#   • home     Synology / supervisor / post-consume + backfill (RECOMMENDED).
#              Poller disabled — post-consume covers new docs, backfill
#              covers everything else. The simplest setup that covers
#              every case.
#   • home+poller  Same as home but adds the polling safety-net for users
#              who can't or don't want to wire PAPERLESS_POST_CONSUME_SCRIPT.

# ── paperless connection ──────────────────────────────────────────────
PAPERLESS_URL=http://paperless:8000
PAPERLESS_TOKEN=replace-me-with-a-paperless-api-token
# Set to false for self-signed / homelab paperless. Default: true.
PAPERLESS_VERIFY_SSL=true
# Or pin to a CA bundle file for proper verification with a private CA.
# When set, this wins over PAPERLESS_VERIFY_SSL.
PAPERLESS_CA_BUNDLE=

# ── paths (defaults shown) ────────────────────────────────────────────
RULES_DIR=/data/rules
STATE_DIR=/data/state

# ── editor ────────────────────────────────────────────────────────────
EDITOR_ENABLED=true
EDITOR_HOST=0.0.0.0
EDITOR_PORT=8765
# Gate the editor behind a paperless API token. Default: true.
# The user pastes their paperless token in the login modal once; the editor
# verifies it against paperless before serving any /api/* call
# (except /api/health). Set to false ONLY on a strictly trusted LAN.
EDITOR_AUTH_REQUIRED=true
# Read-only mode: blocks every mutation (rule writes/deletes, post-consume
# webhook, non-dry-run apply). The editor still loads docs, runs match
# regexes, and shows what a rule WOULD do — perfect for laptop dev.
# Pair with EDITOR_AUTH_REQUIRED=false and a server-side PAPERLESS_TOKEN.
EDITOR_READONLY=false

# ── runtime ───────────────────────────────────────────────────────────
# disabled | poller | post_consume
#
# Recommendation: `disabled` once post-consume is wired (the editor's
# Backfill button covers historical sweeps; the post-consume webhook
# covers new docs). Use `poller` only if you can't or don't want to
# wire PAPERLESS_POST_CONSUME_SCRIPT.
RUNTIME_MODE=disabled
POLL_INTERVAL_SECONDS=60
# Optional paperless query string — only docs matching this get processed.
# e.g. POLL_FILTER=tag:needs-rules  for explicit opt-in.
POLL_FILTER=

# ── logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Per-rule trace lines — set on each rule via top-level `trace: true` to
# see every match/exclude/field outcome in the logs (and inline in the
# editor's Test results). Stays silent for rules that don't opt in.
# Override the trace logger's level here if you want it loud globally:
#   LOG_LEVEL_TRACE=DEBUG  (not yet wired — set logging.getLogger
#   "paperless_rules.trace" manually if needed).
